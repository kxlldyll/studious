local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local isAiming = false
local espObjects = {}

-- Safely allocates full Drawing overlay tables for active players
local function createESP(player)
    if espObjects[player] then return end
    
    espObjects[player] = {
        Tracer = Drawing.new("Line"),
        Box = Drawing.new("Square"),
        NameText = Drawing.new("Text"),
        DistText = Drawing.new("Text")
    }
end

-- Strict memory cleanup routine to wipe out old text/boxes instantly
local function removeESP(player)
    if espObjects[player] then
        for _, object in pairs(espObjects[player]) do
            if object and object.Remove then
                object:Remove()
            end
        end
        espObjects[player] = nil
    end
end

-- Target Finder: Measures pixel distance from your screen center
function getClosestToCrosshair()
    local closestDistance = math.huge
    local closestPlayer = nil
    
    local viewportSize = Camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Team ~= LocalPlayer.Team then
            if LocalPlayer.Character and v.Character and v.Character:FindFirstChild("Head") and v.Character:FindFirstChild("Humanoid") and v.Character:FindFirstChild("HumanoidRootPart") then
                if v.Character.Humanoid.Health > 0 then
                    
                    local screenPos, onScreen = Camera:WorldToViewportPoint(v.Character.Head.Position)
                    
                    if onScreen then
                        local enemyScreenVector = Vector2.new(screenPos.X, screenPos.Y)
                        local distanceFromCenter = (screenCenter - enemyScreenVector).magnitude
                        
                        if distanceFromCenter < closestDistance then
                            closestDistance = distanceFromCenter
                            closestPlayer = v
                        end
                    end
                    
                end
            end 
        end
    end
    return closestPlayer
end

UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        isAiming = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        isAiming = false
    end
end)

Players.PlayerRemoving:Connect(removeESP)

-- Fast execution frame loop (Handles Aimbot, Boxes, Text, and Tracers)
RunService.RenderStepped:Connect(function()
    -- 🎯 SECTION 1: THE AIMBOT TRACKER
    if isAiming then
        local target = getClosestToCrosshair()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.Head.Position)
        end
    end
    
    -- 👁️ SECTION 2: THE FULL VISUAL ESP SUITE
    local viewportSize = Camera.ViewportSize
    local screenBottom = Vector2.new(viewportSize.X / 2, viewportSize.Y)
    local validPlayersThisFrame = {}
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Team ~= LocalPlayer.Team then
            if v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                
                local hrp = v.Character.HumanoidRootPart
                local hrpPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                
                if onScreen then
                    validPlayersThisFrame[v] = true
                    createESP(v)
                    local esp = espObjects[v]
                    
                    -- Dynamic boundary definitions matching the game character scale
                    local topPosition = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                    local bottomPosition = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3.5, 0))
                    
                    local boxHeight = math.abs(topPosition.Y - bottomPosition.Y)
                    local boxWidth = boxHeight / 1.8
                    
                    local displayColor = Color3.fromRGB(255, 0, 0) -- Red for opponents
                    
                    -- 1. Red Bounding Box Outline
                    esp.Box.Visible = true
                    esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                    esp.Box.Position = Vector2.new(hrpPos.X - (boxWidth / 2), hrpPos.Y - (boxHeight / 2))
                    esp.Box.Color = displayColor
                    esp.Box.Thickness = 1.5
                    esp.Box.Filled = false
                    esp.Box.Transparency = 0.8
                    
                    -- 2. Red Tracer Lines
                    esp.Tracer.Visible = true
                    esp.Tracer.From = screenBottom
                    esp.Tracer.To = Vector2.new(hrpPos.X, hrpPos.Y)
                    esp.Tracer.Color = displayColor
                    esp.Tracer.Thickness = 1.5
                    esp.Tracer.Transparency = 0.7
                    
                    -- Calculate precise stud distance
                    local distanceValue = 0
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        distanceValue = (LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    end
                    
                    -- 3. Username Text + [PLAYER] Tag
                    esp.NameText.Visible = true
                    esp.NameText.Text = "[PLAYER] " .. v.Name
                    esp.NameText.Position = Vector2.new(hrpPos.X, hrpPos.Y - (boxHeight / 2) - 24)
                    esp.NameText.Color = Color3.fromRGB(255, 255, 255)
                    esp.NameText.Size = 13
                    esp.NameText.Center = true
                    esp.NameText.Outline = true
                    
                    -- 4. Cyan Stud Distance Tracker
                    esp.DistText.Visible = true
                    esp.DistText.Text = string.format("%.0f Studs", distanceValue)
                    esp.DistText.Position = Vector2.new(hrpPos.X, hrpPos.Y - (boxHeight / 2) - 11)
                    esp.DistText.Color = Color3.fromRGB(0, 255, 255)
                    esp.DistText.Size = 11
                    esp.DistText.Center = true
                    esp.DistText.Outline = true
                else
                    removeESP(v)
                end
            else
                removeESP(v)
            end
        else
            removeESP(v)
        end
    end
    
    -- Sweep loop to instantly erase drawings when opponents get killed or ragdolled
    for player, _ in pairs(espObjects) do
        if not validPlayersThisFrame[player] then
            removeESP(player)
        end
    end
end)
